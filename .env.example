# Copy to .env and fill in. .env is gitignored.

# --- LLM chain (any OpenAI-compatible host). The agent tries these in order and fails over,
# --- so one provider running out of quota never breaks output. Slot 1 (GLM_*) is required;
# --- LLM2/LLM3/LLM4 are optional backups. Use a tool-calling model (llama-3.3-70b, gemini-2.5-
# --- flash, nemotron, mistral-small). Avoid gpt-oss reasoning models — they break tool loops.
GLM_API_KEY=your-groq-key
GLM_BASE_URL=https://api.groq.com/openai/v1
GLM_MODEL=llama-3.3-70b-versatile

# Each slot auto-detects its provider from the base URL, or set <SLOT>_PROVIDER=google|openai.
# Backup 2 — Google Gemini (largest free tier, native @ai-sdk/google — no base URL needed).
# Key: https://aistudio.google.com/apikey
# LLM2_PROVIDER=google
# LLM2_API_KEY=your-gemini-key
# LLM2_MODEL=gemini-2.5-flash

# Backup 3 — NVIDIA NIM (Nemotron). Key: https://build.nvidia.com
# LLM3_API_KEY=your-nvidia-key
# LLM3_BASE_URL=https://integrate.api.nvidia.com/v1
# LLM3_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1

# Backup 4 — Mistral. Key: https://console.mistral.ai
# LLM4_API_KEY=your-mistral-key
# LLM4_BASE_URL=https://api.mistral.ai/v1
# LLM4_MODEL=mistral-small-latest

# --- Scraper service ---
SCRAPER_URL=http://127.0.0.1:7788
SCRAPER_PORT=7788

# --- Database ---
DATABASE_PATH=./data/app.sqlite

# --- Web app ---
PORT=5050
